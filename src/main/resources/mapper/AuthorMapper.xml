<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.library.repository.mybatis.AuthorMapper">

    <resultMap id="AuthorWithBooksMap" type="com.example.library.entity.Author">
        <id property="id" column="author_id"/>
        <result property="name" column="author_name"/>
        <result property="birthDate" column="author_birth_date"/>
        <result property="country" column="author_country"/>

        <collection property="books" ofType="com.example.library.entity.Book" resultMap="BookWithCategoriesMap"/>
    </resultMap>

    <resultMap id="BookWithCategoriesMap" type="com.example.library.entity.Book">
        <id property="id" column="book_id"/>
        <result property="title" column="book_title"/>
        <result property="isbn" column="book_isbn"/>
        <result property="publicationYear" column="book_publication_year"/>

        <association property="author" javaType="com.example.library.entity.Author">
            <id property="id" column="author_id"/>
            <result property="name" column="author_name"/>
        </association>

        <collection property="categories" ofType="com.example.library.entity.Category">
            <id property="id" column="category_id"/>
            <result property="name" column="category_name"/>
            <result property="description" column="category_description"/>
        </collection>
    </resultMap>

    <!-- Find all authors with their books and categories -->
    <select id="findAllWithBooks" resultMap="AuthorWithBooksMap">
        SELECT DISTINCT
            a.id as author_id,
            a.name as author_name,
            a.birth_date as author_birth_date,
            a.country as author_country,
            b.id as book_id,
            b.title as book_title,
            b.isbn as book_isbn,
            b.publication_year as book_publication_year,
            c.id as category_id,
            c.name as category_name,
            c.description as category_description
        FROM authors a
                 LEFT JOIN books b ON a.id = b.author_id
                 LEFT JOIN book_categories bc ON b.id = bc.book_id
                 LEFT JOIN categories c ON bc.category_id = c.id
        ORDER BY a.id, b.id, c.id
    </select>

</mapper>