<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.library.repository.mybatis.BookMapper">

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO books (title, isbn, publication_year, author_id)
        VALUES (#{title}, #{isbn}, #{publicationYear}, #{author.id})
    </insert>

    <select id="findByIdWithDetails" resultType="com.example.library.entity.Book">
        SELECT * FROM books WHERE id = #{id}
    </select>
</mapper>